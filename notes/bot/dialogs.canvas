		{"id":"f129d4bad227675a","type":"text","text":"/random\n\n🎲 *Судьба выбирает для тебя замок\\.\\.\\.*","x":-2780,"y":-343,"width":400,"height":80},
		{"id":"aadd_type","type":"text","text":"🏷️ Шаг 2/2 · Выберите тип автора\n\n[inline kb: 5 типов на страницу]\n◀ Назад · Далее ▶","x":2050,"y":-1090,"width":400,"height":110},
		{"id":"aadd_confirm","type":"text","text":"📋 Подтвердите:\n\n👤 [имя]\n🏷️ [тип автора]\n\n[inline kb: ✅ Сохранить | ❌ Отмена]","x":2050,"y":-940,"width":400,"height":120},
		{"id":"aadd_name","type":"text","text":"/addauthor\n\n🏗️ *Ты принимаешь нового летописца в братство\\!*\n\nШаг 1/2 · Введите имя автора:","x":2050,"y":-1240,"width":400,"height":110},
		{"id":"aadd_ok","type":"text","text":"✅ *Новый летописец вписан в анналы CastleKeeper\\!*\n\nТеперь его имя будут помнить века\\.","x":2050,"y":-780,"width":350,"height":80},
		{"id":"aadd_back","type":"text","text":"<center>/authormenu</center>","x":2050,"y":-660,"width":350,"height":50},
		{"id":"atypemenu_text","type":"text","text":"/atypemenu\n\n🏷️ *Ты входишь в Зал Титулов\\.*\n\nНа стенах висят гербы с именами званий: Строитель, Летописец, Архитектор, Хронист\\.\\.\\.\n\nКаждый автор носит один из этих титулов\\.\n\nЧто хочешь сделать с титулами?","x":3095,"y":-1510,"width":450,"height":310},
		{"id":"atbtn_all","type":"text","text":"<center>📜 Все</center>","x":3095,"y":-1180,"width":105,"height":50},
		{"id":"atbtn_add","type":"text","text":"<center>🏗️ Добавить</center>","x":3210,"y":-1180,"width":105,"height":50},
		{"id":"atbtn_edit","type":"text","text":"<center>✒️ Изменить</center>","x":3325,"y":-1180,"width":105,"height":50},
		{"id":"atbtn_delete","type":"text","text":"<center>💥 Удалить</center>","x":3440,"y":-1180,"width":105,"height":50},
		{"id":"atbtn_back","type":"text","text":"<center>↩️ К авторам</center>","x":3095,"y":-1115,"width":450,"height":50},
		{"id":"atlist_msg","type":"text","text":"/author_types\n\n📜 *Список всех титулов\\.\\.\\.*","x":3100,"y":-880,"width":400,"height":70},
		{"id":"atlist_out","type":"text","text":"<center>вывод всех типов\n(текст, без кнопок)</center>","x":3200,"y":-770,"width":200,"height":60},
		{"id":"atlist_back","type":"text","text":"<center>/atypemenu</center>","x":3200,"y":-670,"width":200,"height":50},

		{"id":"reconmenu_text","type":"text","text":"/reconstructionmenu\n\n🔨 *Ты входишь в Крыло Реконструкций\\.*\n\nНа стенах — чертежи и схемы перестроек замков\\. Здесь записана история каждого обновления твердынь — кто, когда и какой замок перестраивал\\.\n\nЧто хочешь изучить или записать?","x":5400,"y":-1300,"width":430,"height":310},
		{"id":"rbtn_all","type":"text","text":"<center>📜 Все</center>","x":5400,"y":-970,"width":105,"height":50},
		{"id":"rbtn_pick","type":"text","text":"<center>👁️ Выбрать</center>","x":5515,"y":-970,"width":105,"height":50},
