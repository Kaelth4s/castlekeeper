		{"id":"rbtn_delete","type":"text","text":"<center>💥 Удалить</center>","x":5575,"y":-905,"width":160,"height":50},
		{"id":"rbtn_back","type":"text","text":"<center>↩️ В главный зал</center>","x":5400,"y":-840,"width":335,"height":50},

		{"id":"rlist_msg","type":"text","text":"/reconstructions\n\n🔨 *Список всех реконструкций\\.\\.\\.*","x":5400,"y":-760,"width":400,"height":70},
