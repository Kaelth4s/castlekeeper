		{"id":"mbtn_delete","type":"text","text":"<center>💥 Удалить</center>","x":1345,"y":-105,"width":130,"height":50},
		{"id":"mbtn_back","type":"text","text":"<center>↩️ В главный зал</center>","x":1490,"y":-105,"width":130,"height":50},
		{"id":"mlist_msg","type":"text","text":"/materials\n\n🧱 *Ты входишь в каменоломню и разворачиваешь свиток со списком всех материалов\\.\\.\\.*","x":4000,"y":-2000,"width":400,"height":80},
		{"id":"mlist_out","type":"text","text":"<center>вывод всех материалов\n(текст, без кнопок)</center>","x":4100,"y":-1880,"width":200,"height":60},
