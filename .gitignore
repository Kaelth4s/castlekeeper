# =====================
# Obsidian (настройки vault)
# =====================
# Файлы состояния рабочего пространства – генерируются заново, создают конфликты
.obsidian/workspace*.json
.obsidian/workspace-mobile*.json
.obsidian/.hotreload
.obsidian/cache
copilot/

# Корзина Obsidian (если vault в корне)
.trash/

# =====================
# Секреты и локальные переменные
# =====================
.env
# Игнорируем только настоящий .env с паролями; .env.example можно коммитить

# =====================
# Java / Maven
# =====================
# Скомпилированные классы
*.class
*.jar
*.war

# Папки сборки Maven (результаты компиляции)
target/
bot/target/
server/target/

# Для Gradle (если вдруг появится)
build/
.gradle/

# =====================
# IntelliJ IDEA (личные настройки разработчика)
# =====================
.idea/
# Если ты хочешь коммитить некоторые общие настройки (например, code style),
# лучше использовать общий формат EditorConfig и исключить .idea/ целиком
*.iml

# =====================
# Файлы операционной системы
# =====================
.DS_Store
Thumbs.db
$RECYCLE.BIN/

# =====================
# Docker (если volume случайно примонтирован в папку проекта)
# =====================
pgdata/

# =====================
# Дополнительные временные файлы
# =====================
*.log
*.tmp