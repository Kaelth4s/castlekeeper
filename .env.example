# ==============================
# CastleKeeper — Environment Variables
# ==============================
# Copy this file to .env and fill in the values.
# .env is git-ignored and never committed.

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=castlekeeper
DB_USER=
DB_PASSWORD=

# --- Server ---
SERVER_PORT=8080
DOMAIN=castlekeeper.example.com

# --- Flyway (optional overrides, defaults use DB_* vars above) ---
# FLYWAY_URL=jdbc:postgresql://${DB_HOST}:${DB_PORT}/${DB_NAME}
# FLYWAY_USER=${DB_USER}
# FLYWAY_PASSWORD=${DB_PASSWORD}
