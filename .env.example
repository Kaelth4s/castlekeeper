 # ==============================
# CastleKeeper — Environment Variables
# ==============================
# Copy this file to .env and fill in the values.
# .env is git-ignored and never committed.

# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- Server (REST API) ---
SERV_PORT=8080

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=
BOT_PORT=8081

# --- Domain (optional — for production reverse proxy) ---
# DOMAIN=castlekeeper.example.com
